# Navigation
alias ..='cd ../'
alias ...='cd ../..'
alias .3='cd ../../..'
alias .4='cd ../../../..'
alias dot='cd ~/src/dotfiles/'
alias sa='cd ~/src/ansible/'

# Git
alias gst='git status'
alias gp='git push'
alias gcm='git commit -m '

# System
alias ll='ls -al'
alias python='python3'

# Lazy
alias lzg='lazygit'
alias lzd='lazydocker'

# Obsidian
alias oo='cd ~/Documents/simplycycling'
alias or='nvim ~/Documents/simplycycling/Inbox/*.md'

